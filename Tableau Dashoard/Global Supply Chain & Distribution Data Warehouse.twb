          <datasource-dependencies datasource='federated.1cuuh3r0gpd1wt1fzi9ma15irzsm'>
            <column caption='Category' datatype='string' name='[CATEGORY]' role='dimension' type='nominal' />
            <column caption='PY shipping cost' datatype='real' name='[CY shipping cost (copy)_1406888970616835]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='IF YEAR([SHIP_DATE]) = [Parameters].[Parameter 1]-1 THEN [SHIPPING_COST] END' />
            </column>
            <column caption='CY shipping cost' datatype='real' name='[Calculation_1406888969895938]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='IF YEAR([SHIP_DATE]) = [Parameters].[Parameter 1] THEN [SHIPPING_COST] END' />
            </column>
            <column caption='diff% shipping cost' datatype='real' default-format='p0.0%' name='[Calculation_1406888971657220]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='(SUM([Calculation_1406888969895938])-SUM([CY shipping cost (copy)_1406888970616835]))/SUM([CY shipping cost (copy)_1406888970616835])' />
            </column>
            <column caption='{SUM([CY shipping cost])}' datatype='real' name='[Calculation_1406888972488709]' role='measure' type='quantitative' user:unnamed='kpi1'>
              <calculation class='tableau' formula='{SUM([Calculation_1406888969895938])}' />
            </column>
            <column caption='min/max shipping cost' datatype='real' name='[Calculation_1406888974843910]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='IF SUM([Calculation_1406888969895938]) = WINDOW_MAX(SUM([Calculation_1406888969895938]))&#13;&#10;THEN SUM([Calculation_1406888969895938])&#13;&#10;ELSEIF SUM([Calculation_1406888969895938]) = WINDOW_MIN(SUM([Calculation_1406888969895938]))&#13;&#10;THEN SUM([Calculation_1406888969895938])&#13;&#10;END'>
                <table-calc ordering-type='Rows' />
              </calculation>
            </column>
            <column caption='{[diff% shipping cost]}' datatype='real' name='[Calculation_1406888976982024]' role='measure' type='quantitative' user:unnamed='kpi1'>
              <calculation class='tableau' formula='{[Calculation_1406888971657220]}' />
            </column>
            <column caption='Defect Type' datatype='string' name='[DEFECT_TYPE]' role='dimension' type='nominal' />
