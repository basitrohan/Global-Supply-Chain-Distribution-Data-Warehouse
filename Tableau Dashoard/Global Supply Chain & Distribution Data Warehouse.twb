            <run fontname='Tableau Medium' fontsize='9'><![CDATA[<[federated.1cuuh3r0gpd1wt1fzi9ma15irzsm].[sum:Calculation_1406888976982024:qk]> ]]></run>
            <run fontcolor='#c0c0c0' fontname='Tableau Medium' fontsize='9'>vs Py</run>
          </formatted-text>
        </title>
