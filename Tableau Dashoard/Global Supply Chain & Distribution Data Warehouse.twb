            <column caption='min/max avg lead time crisis' datatype='real' datatype-customized='true' default-format='n#,##0;-#,##0' name='[min/max quanity (copy)_1406889061957679]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='(IF([Calculation_0835142696239105]) = WINDOW_MAX([Calculation_0835142696239105])&#13;&#10;THEN ([Calculation_0835142696239105])&#13;&#10;ELSEIF ([Calculation_0835142696239105]) = WINDOW_MIN([Calculation_0835142696239105])&#13;&#10;THEN([Calculation_0835142696239105])&#13;&#10;END)'>
