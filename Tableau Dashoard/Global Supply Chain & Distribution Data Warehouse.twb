            <column caption='PY avg lead time' datatype='real' name='[CY avg lead time (copy)_1406889060630572]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='AVG(IF YEAR([SHIP_DATE]) = [Parameters].[Parameter 1]-1 THEN [DELIVERY_DATE] - [SHIP_DATE] END)' />
            </column>
            <column caption='CY avg lead time' datatype='real' name='[Calculation_0835142696239105]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='AVG(IF YEAR([SHIP_DATE]) = [Parameters].[Parameter 1] THEN [DELIVERY_DATE] - [SHIP_DATE] END)' />
            </column>
            <column caption='Defect Type' datatype='string' name='[DEFECT_TYPE]' role='dimension' type='nominal' />
